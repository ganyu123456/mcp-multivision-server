# ---- 运行镜像（离线部署时取消注释并指向本地或 Harbor 镜像）----
# MCP_IMAGE=harbor.zkjgy.online/library/mcp-multivision-server:latest
# docker load -i mcp-multivision-server_v1.0.0_linux-amd64.tar.gz
# MCP_IMAGE=mcp-multivision-server:v1.0.0

MCP_PORT=8093
MCP_TRANSPORT=sse

# ---- 云端视觉大模型（OpenAI 兼容接口，一份配置切任意一家）----
# 通义千问VL: base_url=https://dashscope.aliyuncs.com/compatible-mode/v1  model=qwen-vl-max
# 智谱GLM-4V: base_url=https://open.bigmodel.cn/api/paas/v4              model=glm-4v
# 豆包:       base_url=https://ark.cn-beijing.volces.com/api/v3          model=doubao-vision-pro-32k
# OpenAI:     base_url=https://api.openai.com/v1                         model=gpt-4o
MCP_VISION_PROVIDER=openai
MCP_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MCP_VISION_API_KEY=
MCP_VISION_MODEL=qwen-vl-max

# ---- 模型调用参数 ----
MCP_VISION_MAX_TOKENS=1024
MCP_VISION_TEMPERATURE=0.2
MCP_VISION_TIMEOUT=60          # 秒；本地模型可调大
MCP_VISION_MAX_RETRIES=3
MCP_VISION_MAX_FRAMES=8        # analyze_video 送给模型的最大帧数

# ---- 输入校验 ----
MCP_VISION_MAX_IMAGE_SIZE=20971520                 # 20MB
MCP_VISION_ALLOWED_IMAGE_FORMATS=jpeg,png,webp,gif,bmp,tiff

# ---- 可选缓存（SHA256(图+prompt+model)），默认关闭 ----
MCP_VISION_CACHE_ENABLED=false
MCP_VISION_CACHE_DIR=/tmp/mcp-vision-cache

# ---- 抽帧/音轨临时目录 ----
MCP_VISION_WORK_DIR=/tmp/mcp-vision

# ---- ffmpeg 二进制（留空则用 PATH；容器内为 /usr/local/bin）----
MCP_FFMPEG_BIN=
MCP_FFPROBE_BIN=

MCP_VERSION=latest
