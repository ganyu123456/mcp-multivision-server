# ---- 运行镜像（离线部署时取消注释并指向本地或 Harbor 镜像）----
# MCP_IMAGE=harbor.zkjgy.online/library/mcp-multivision-server:latest
# docker load -i mcp-multivision-server_v2.0.0_linux-amd64.tar.gz
# MCP_IMAGE=mcp-multivision-server:v2.0.0

MCP_PORT=8093
MCP_TRANSPORT=sse

# ---- 云端视觉大模型（OpenAI 兼容接口，一份配置切任意一家）----
# 视频走原生理解（不本地抽帧），需选支持原生视频的模型：
#   通义千问3.5:  base_url=https://dashscope.aliyuncs.com/compatible-mode/v1  model=qwen3.5-plus
#   通义千问VL:   base_url=https://dashscope.aliyuncs.com/compatible-mode/v1  model=qwen-vl-max
#   智谱GLM-4V:   base_url=https://open.bigmodel.cn/api/paas/v4              model=glm-4v
#   OpenAI:      base_url=https://api.openai.com/v1                         model=gpt-4o  (注：仅图片，不支持 video_url)
MCP_VISION_PROVIDER=openai
MCP_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MCP_VISION_API_KEY=
MCP_VISION_MODEL=qwen3.5-plus

# ---- 模型调用参数 ----
MCP_VISION_MAX_TOKENS=1024
MCP_VISION_TEMPERATURE=0.2
MCP_VISION_TIMEOUT=120         # 秒；视频理解较慢，建议 120+
MCP_VISION_MAX_RETRIES=3

# ---- 输入校验 ----
MCP_VISION_MAX_IMAGE_SIZE=20971520          # 20MB（单图 base64 上限）
MCP_VISION_MAX_VIDEO_SIZE=104857600         # 100MB（本地视频转 base64 上限；更大请传 http URL）
MCP_VISION_ALLOWED_IMAGE_FORMATS=jpeg,png,webp,gif,bmp,tiff

# ---- 可选缓存（SHA256(输入+prompt+model)），默认关闭 ----
MCP_VISION_CACHE_ENABLED=false
MCP_VISION_CACHE_DIR=/tmp/mcp-vision-cache

MCP_VERSION=latest
